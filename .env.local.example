# Configuration EmailJS (Sécurisée)
# ==================================
# Ces variables sont requises pour l'envoi d'emails sécurisé via la route API

# Flag DEBUG pour les logs détaillés (true/false)
# Activez pour voir tous les logs, désactivez en production
DEBUG=false

# Clé publique EmailJS (peut être publique)
# Disponible dans: EmailJS Dashboard > Account > API Keys
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here

# ID du service EmailJS (à garder SECRET)
# Disponible dans: EmailJS Dashboard > Email Services
EMAILJS_SERVICE_ID=your_service_id_here

# ID du template EmailJS (à garder SECRET)
# Disponible dans: EmailJS Dashboard > Email Templates
EMAILJS_TEMPLATE_ID=your_template_id_here

# Token d'accès EmailJS (à garder SECRET - utilisé côté serveur)
# Généré via: EmailJS Dashboard > Account > Security > API Tokens
EMAILJS_ACCESS_TOKEN=your_access_token_here
